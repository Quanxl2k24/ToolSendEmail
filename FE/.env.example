# Google OAuth 2.0 Web Client ID
# Lấy từ: GCP Console > APIs & Services > Credentials > OAuth 2.0 Web Client
VITE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# Backend API URL (mặc định BE chạy port 3000)
VITE_API_URL=http://localhost:3000

# Google OAuth Redirect URI (phải khớp với Authorized Redirect URIs trên GCP Console)
VITE_GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Email quota & rate limit (phải đồng bộ với BE)
VITE_DAILY_LIMIT=400
VITE_RATE_LIMIT=1
