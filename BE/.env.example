# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/tool_send_email"

# ── Redis (BullMQ Queue) ───────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password  # Uncomment if Redis requires auth

# ── SMTP ───────────────────────────────────────────────────────────────────────
# SMTP_MODE=sandbox      # Ethereal.email (test ảo, xem mail trên web)
# SMTP_MODE=production   # (mặc định) Gửi thật qua SMTP bên dưới
#
# Gmail example: Use App Password (not your regular password)
# Enable 2FA -> Google Account -> Security -> App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM="Your Name <your_email@gmail.com>"
SMTP_RATE_LIMIT=1           # Email tối đa mỗi giây
SMTP_DAILY_QUOTA=400        # Email tối đa mỗi ngày (Gmail free: ~500)

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# Needed for the frontend to obtain an access_token for Google Sign-In.
# The backend uses this token to read Google Sheets on behalf of the user.
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret  # Only needed if backend handles OAuth flow

# ── Token Encryption ──────────────────────────────────────────────────────────
# AES-256 key used to encrypt OAuth tokens before storing in DB.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# TOKEN_ENCRYPTION_KEY= your_64_char_hex_string_here

# ── Frontend ───────────────────────────────────────────────────────────────────
# Used for CORS and Socket.io origin whitelist
FRONTEND_URL=http://localhost:5173
